{{- if .use_fish | default false }}
# Ensure ~/.local/bin is in PATH for user-installed binaries
set -gx PATH $HOME/.local/bin $PATH

# Load centralized environment variables natively
if test -f ~/.config/shell/env.list
    for line in (cat ~/.config/shell/env.list)
        # Ignore empty lines and lines starting with '#'
        if test -n "$line"; and not string match -q '#*' "$line"
            set -l kv (string split -m 1 '=' $line)
            set -gx $kv[1] $kv[2]
        end
    end
end

# Load centralized aliases (fish is compatible with basic bash alias syntax)
if test -f ~/.config/shell/aliases.sh
    source ~/.config/shell/aliases.sh
end

# Shared helper functions for interactive use in fish
function mkd
    if test (count $argv) -lt 1
        printf '%s\n' 'usage: mkd <dir>' >&2
        return 1
    end
    mkdir -p $argv[1]; and cd $argv[1]
end

function dpsg
    set -l docker_ps_format 'table {{ printf "{{.ID}}" }}\t{{ printf "{{.Names}}" }}\t{{ printf "{{.Ports}}" }}\t{{ printf "{{.Image}}" }}\t{{ printf "{{.Status}}" }}'
    if test (count $argv) -gt 0
        docker ps --format "$docker_ps_format" | grep -i "$argv[1]"
    else
        docker ps --format "$docker_ps_format"
    end
end

function dlog
    if test (count $argv) -lt 1
        printf '%s\n' 'usage: dlog <container>' >&2
        return 1
    end
    docker logs -f $argv[1]
end

function dsh
    if test (count $argv) -lt 1
        printf '%s\n' 'usage: dsh <container>' >&2
        return 1
    end
    docker exec -it $argv[1] sh
end

function dbash
    if test (count $argv) -lt 1
        printf '%s\n' 'usage: dbash <container>' >&2
        return 1
    end
    docker exec -it $argv[1] bash 2>/dev/null; or docker exec -it $argv[1] sh
end

function dins
    if test (count $argv) -lt 1
        printf '%s\n' 'usage: dins <container>' >&2
        return 1
    end
    docker inspect $argv[1]
end

# Initialize Fuzzy Finder key bindings for fish
if command -q fzf
  if fzf --fish >/dev/null 2>/dev/null
    fzf --fish | source
  else if test -f /usr/share/fish/vendor_functions.d/fzf_key_bindings.fish
    source /usr/share/fish/vendor_functions.d/fzf_key_bindings.fish
  else if test -f /usr/share/doc/fzf/examples/key-bindings.fish
    source /usr/share/doc/fzf/examples/key-bindings.fish
  end
end

# Initialize smarter cd command (z) for fish
if command -q zoxide
  zoxide init fish | source
end

# Initialize the cross-shell customizable prompt
if command -q starship
  set -gx STARSHIP_CONFIG $HOME/.config/starship.toml
  starship init fish | source
end
{{- end }}
