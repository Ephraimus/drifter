# Default terminal editor for git commits, crontab, etc.
EDITOR=vim
# Visual editor for commands like `fc`
VISUAL=vim
# Default pager for viewing long outputs (like man pages)
PAGER=less
# Let `less` interpret ANSI color escape sequences
LESS=-R
# Set default locale to UTF-8
LANG=en_US.UTF-8

# FZF (Fuzzy Finder) Configuration
# Provides syntax-highlighted file previews on the right side using bat/batcat (or falls back to standard cat)
FZF_DEFAULT_OPTS=--preview 'bat --color=always {} 2>/dev/null || batcat --color=always {} 2>/dev/null || cat {}'
