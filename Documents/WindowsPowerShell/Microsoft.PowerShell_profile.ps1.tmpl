# Microsoft.PowerShell_profile.ps1.tmpl
# Drifter — Windows PowerShell 5.1 Profile
# Managed by Chezmoi. Do NOT edit this file directly.

# ----- legacy -----
$legacyProfile = Join-Path (Split-Path -Parent $PROFILE) 'Microsoft.PowerShell_profile.legacy.ps1'
if (Test-Path $legacyProfile) {
  . $legacyProfile
}

# ----- environment variables -----
$envFile = Join-Path $HOME ".config/shell/env.list"
if (Test-Path $envFile) {
  Get-Content $envFile | ForEach-Object {
    $line = $_.Trim()
    if ($line -and $line -notmatch '^\s*#') {
      $parts = $line -split '=', 2
      if ($parts.Count -eq 2) {
        [System.Environment]::SetEnvironmentVariable($parts[0].Trim(), $parts[1].Trim(), 'Process')
      }
    }
  }
}

# ----- PATH -----
if (Test-Path "$HOME\.local\bin") {
  $env:PATH = "$HOME\.local\bin;$env:PATH"
}

# ----- modern CLI aliases -----
if (Get-Command eza -ErrorAction SilentlyContinue) {
  function ls   { eza --icons=auto --color=auto @args }
  function ll   { eza -lh --icons=auto @args }
  function la   { eza -la --icons=auto @args }
  function tree { eza --tree --icons=auto @args }
} else {
  function ll { Get-ChildItem -Force @args }
  function la { Get-ChildItem -Force @args }
}

if (Get-Command bat -ErrorAction SilentlyContinue) {
  function cat { bat --paging=never @args }
}

# ----- git shortcuts -----
function gs  { git status -sb @args }
function ga  { git add @args }
function gc  { git commit @args }
function gca { git commit --amend @args }
function gp  { git push @args }
function gl  { git pull @args }

# ----- utilities -----
function c   { Clear-Host }
function mkd {
  if (-not $args -or -not $args[0]) {
    throw "mkd requires a target directory."
  }

  New-Item -ItemType Directory -Path $args[0] -Force | Out-Null
  Set-Location $args[0]
}

# ----- zoxide -----
if (Get-Command zoxide -ErrorAction SilentlyContinue) {
  Invoke-Expression (& { zoxide init powershell | Out-String })
}

# ----- fzf -----
if (Get-Module -ListAvailable -Name PSFzf -ErrorAction SilentlyContinue) {
  Import-Module PSFzf
  Set-PsFzfOption -PSReadlineChordProvider 'Ctrl+t' -PSReadlineChordReverseHistory 'Ctrl+r'
}

# ----- starship -----
if (Get-Command starship -ErrorAction SilentlyContinue) {
  $env:STARSHIP_CONFIG = Join-Path $HOME ".config/starship.toml"
  Invoke-Expression (&starship init powershell)
}
